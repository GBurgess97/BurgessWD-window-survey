<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Surveyor Portal — Burgess Windows & Doors</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:14px;color:#1a1a1a;background:#f5f5f3;min-height:100vh}
.app-header{background:#1e40af;padding:14px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.app-title{font-size:16px;font-weight:600;color:#fff}
.app-subtitle{font-size:12px;color:#93c5fd;margin-top:1px}
.container{max-width:800px;margin:0 auto;padding:20px 16px}

/* Login screen */
.login-screen{display:flex;align-items:center;justify-content:center;min-height:80vh}
.login-card{background:#fff;border:1px solid #e5e5e5;border-radius:14px;padding:32px;max-width:400px;width:100%;text-align:center;box-shadow:0 4px 24px rgba(0,0,0,0.06)}
.login-logo{width:56px;height:56px;background:#1e40af;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px}
.login-logo svg{width:30px;height:30px;fill:none;stroke:#fff;stroke-width:2}
.login-title{font-size:20px;font-weight:700;margin-bottom:6px}
.login-sub{font-size:13px;color:#64748b;margin-bottom:24px;line-height:1.6}
.login-field{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;text-align:left}
.login-field label{font-size:12px;font-weight:600;color:#374151}
.login-field input{padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:14px;font-family:inherit;outline:none;transition:border-color 0.15s}
.login-field input:focus{border-color:#3b82f6}
.login-btn{width:100%;padding:12px;background:#1e40af;color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:background 0.15s}
.login-btn:hover{background:#1d4ed8}
.login-btn:disabled{background:#93c5fd;cursor:not-allowed}

/* Dashboard */
.dashboard{display:none}
.welcome-bar{background:#fff;border:1px solid #e5e5e5;border-radius:10px;padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.welcome-name{font-size:16px;font-weight:600}
.welcome-sub{font-size:12px;color:#64748b;margin-top:2px}
.btn-signout{background:transparent;border:1px solid #e0e0e0;color:#64748b;padding:6px 14px;border-radius:7px;font-size:12px;cursor:pointer;font-family:inherit}
.btn-signout:hover{background:#f5f5f5}

/* Stats */
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px}
.stat-card{background:#fff;border:1px solid #e5e5e5;border-radius:10px;padding:14px;text-align:center}
.stat-val{font-size:28px;font-weight:700;margin-bottom:2px}
.stat-lbl{font-size:11px;color:#888}
.stat-card.outstanding .stat-val{color:#d97706}
.stat-card.complete .stat-val{color:#059669}
.stat-card.total .stat-val{color:#1e40af}

/* Jobs list */
.jobs-section{background:#fff;border:1px solid #e5e5e5;border-radius:10px;overflow:hidden;margin-bottom:16px}
.jobs-header{padding:14px 18px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.jobs-title{font-size:15px;font-weight:600}
.filter-tabs{display:flex;gap:4px}
.ftab{padding:5px 12px;border:1px solid #e0e0e0;border-radius:6px;background:transparent;color:#888;font-size:12px;cursor:pointer;font-family:inherit}
.ftab.active{background:#1e40af;color:#fff;border-color:#1e40af}

.job-item{padding:14px 18px;border-bottom:1px solid #f5f5f5;display:flex;align-items:center;gap:12px;cursor:pointer;transition:background 0.1s}
.job-item:last-child{border-bottom:none}
.job-item:hover{background:#f8fafc}
.job-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.job-dot.booked{background:#f59e0b}
.job-dot.confirmed{background:#3b82f6}
.job-dot.complete{background:#10b981}
.job-main{flex:1;min-width:0}
.job-name{font-weight:600;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.job-meta{font-size:12px;color:#64748b;margin-top:2px}
.job-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0}
.job-status{font-size:11px;font-weight:500;padding:2px 8px;border-radius:5px;white-space:nowrap}
.status-booked{background:#fef3c7;color:#92400e}
.status-confirmed{background:#dbeafe;color:#1e40af}
.status-complete{background:#d1fae5;color:#065f46}
.job-arrow{color:#cbd5e1;font-size:16px}
.job-date{font-size:11px;color:#9ca3af}

/* Empty state */
.empty-state{padding:40px 20px;text-align:center;color:#9ca3af}
.empty-icon{font-size:40px;margin-bottom:10px}
.empty-title{font-size:15px;font-weight:600;color:#64748b;margin-bottom:4px}
.empty-sub{font-size:13px}

/* Loading */
.loading{padding:40px 20px;text-align:center;color:#9ca3af}
.spinner{width:28px;height:28px;border:3px solid #e5e5e5;border-top-color:#1e40af;border-radius:50%;animation:spin 0.7s linear infinite;margin:0 auto 12px}
@keyframes spin{to{transform:rotate(360deg)}}

/* Refresh btn */
.btn-refresh{background:#eff6ff;border:1px solid #bfdbfe;color:#1e40af;padding:6px 14px;border-radius:7px;font-size:12px;cursor:pointer;font-family:inherit;font-weight:500}
.btn-refresh:hover{background:#dbeafe}

.error-box{background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:12px 16px;font-size:13px;color:#991b1b;margin-bottom:14px}

@media(max-width:500px){.stats-grid{grid-template-columns:repeat(3,1fr)}.stat-val{font-size:22px}}
</style>
</head>
<body>

<div class="app-header">
  <div>
    <div class="app-title">Burgess Windows &amp; Doors</div>
    <div class="app-subtitle">Surveyor Portal</div>
  </div>
  <div id="header-name" style="color:#93c5fd;font-size:13px;display:none"></div>
</div>

<div class="container">

  <!-- Login -->
  <div class="login-screen" id="login-screen">
    <div class="login-card">
      <div class="login-logo">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <div class="login-title">Surveyor Portal</div>
      <div class="login-sub">Enter your name to see your assigned jobs and manage your surveys.</div>
      <div class="login-field">
        <label>Your name</label>
        <input type="text" id="login-name" placeholder="e.g. George Burgess" oninput="checkLogin()" onkeydown="if(event.key==='Enter')doLogin()">
      </div>
      <button class="login-btn" id="login-btn" onclick="doLogin()" disabled>View my jobs</button>
    </div>
  </div>

  <!-- Dashboard -->
  <div class="dashboard" id="dashboard">
    <div class="welcome-bar">
      <div>
        <div class="welcome-name" id="welcome-name"></div>
        <div class="welcome-sub">Here are your assigned survey jobs</div>
      </div>
      <div style="display:flex;gap:8px;align-items:center">
        <button class="btn-refresh" onclick="loadJobs()">Refresh</button>
        <button class="btn-signout" onclick="signOut()">Sign out</button>
      </div>
    </div>

    <div id="error-box" class="error-box" style="display:none"></div>

    <div class="stats-grid">
      <div class="stat-card outstanding"><div class="stat-val" id="stat-outstanding">—</div><div class="stat-lbl">Outstanding</div></div>
      <div class="stat-card complete"><div class="stat-val" id="stat-complete">—</div><div class="stat-lbl">Completed</div></div>
      <div class="stat-card total"><div class="stat-val" id="stat-total">—</div><div class="stat-lbl">Total jobs</div></div>
    </div>

    <div class="jobs-section">
      <div class="jobs-header">
        <div class="jobs-title">Your jobs</div>
        <div class="filter-tabs">
          <button class="ftab active" onclick="filterJobs('all',this)">All</button>
          <button class="ftab" onclick="filterJobs('outstanding',this)">Outstanding</button>
          <button class="ftab" onclick="filterJobs('complete',this)">Complete</button>
        </div>
      </div>
      <div id="jobs-list">
        <div class="loading"><div class="spinner"></div>Loading your jobs...</div>
      </div>
    </div>
  </div>

</div>

<script>
const BOARD_ID='18402849501';
const PROXY_API='/.netlify/functions/monday-proxy';
const SURVEY_URL='https://fascinating-crumble-d9b34d.netlify.app/';

let currentUser='';
let allJobs=[];
let currentFilter='all';

function checkLogin(){
  const val=document.getElementById('login-name').value.trim();
  document.getElementById('login-btn').disabled=val.length<2;
}

function doLogin(){
  const name=document.getElementById('login-name').value.trim();
  if(name.length<2)return;
  currentUser=name;
  localStorage.setItem('bwd_portal_user',name);
  showDashboard();
}

function signOut(){
  localStorage.removeItem('bwd_portal_user');
  currentUser='';
  allJobs=[];
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('dashboard').style.display='none';
  document.getElementById('header-name').style.display='none';
  document.getElementById('login-name').value='';
  document.getElementById('login-btn').disabled=true;
}

function showDashboard(){
  document.getElementById('login-screen').style.display='none';
  document.getElementById('dashboard').style.display='block';
  document.getElementById('welcome-name').textContent='Welcome, '+currentUser;
  document.getElementById('header-name').textContent=currentUser;
  document.getElementById('header-name').style.display='block';
  loadJobs();
}

async function loadJobs(){
  document.getElementById('jobs-list').innerHTML='<div class="loading"><div class="spinner"></div>Loading your jobs...</div>';
  document.getElementById('error-box').style.display='none';
  document.getElementById('stat-outstanding').textContent='—';
  document.getElementById('stat-complete').textContent='—';
  document.getElementById('stat-total').textContent='—';

  try{
    // First fetch column metadata to get IDs by title
    const colQuery=`query { boards(ids:${BOARD_ID}){ columns{ id title type } } }`;
    const colRes=await fetch(PROXY_API,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:colQuery})});
    const colData=await colRes.json();
    if(colData.errors)throw new Error(colData.errors[0].message);
    const columns=colData.data?.boards?.[0]?.columns||[];

    // Find column IDs by title
    const surveyorColId=columns.find(c=>c.title==='Surveyor'||c.type==='people')?.id||'';
    const statusColId=columns.find(c=>c.title==='Survey Status'||c.title==='Status'||c.type==='color')?.id||'';
    const dateColId=columns.find(c=>c.title.toLowerCase().includes('date')||c.type==='date')?.id||'';

    // Now fetch items with column values
    const query=`query {
      boards(ids:${BOARD_ID}){
        items_page(limit:200){
          items {
            id
            name
            column_values {
              id
              text
              ... on PeopleValue { persons_and_teams { id name } }
              ... on StatusValue { label }
              ... on DateValue { date }
            }
          }
        }
      }
    }`;

    const res=await fetch(PROXY_API,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({query})
    });

    if(!res.ok)throw new Error('Server error '+res.status);
    const data=await res.json();
    if(data.errors)throw new Error(data.errors[0].message);

    const items=data.data?.boards?.[0]?.items_page?.items||[];

    // Filter to jobs assigned to this surveyor
    allJobs=items.filter(item=>{
      const surveyorCol=item.column_values.find(c=>c.id===surveyorColId);
      if(!surveyorCol)return false;
      const persons=surveyorCol.persons_and_teams||[];
      const nameMatch=persons.some(p=>
        p.name.toLowerCase().includes(currentUser.toLowerCase())||
        currentUser.toLowerCase().includes(p.name.toLowerCase())
      );
      const textMatch=(surveyorCol.text||'').toLowerCase().includes(currentUser.toLowerCase());
      return nameMatch||textMatch;
    }).map(item=>{
      const statusCol=item.column_values.find(c=>c.id===statusColId);
      const dateCol=item.column_values.find(c=>c.id===dateColId);
      return{
        id:item.id,
        name:item.name,
        status:statusCol?.label||statusCol?.text||'—',
        date:dateCol?.date||dateCol?.text||'',
      };
    });

    renderJobs();
    updateStats();

  }catch(err){
    document.getElementById('jobs-list').innerHTML='<div class="empty-state"><div class="empty-title">Could not load jobs</div><div class="empty-sub">'+err.message+'</div></div>';
    const eb=document.getElementById('error-box');
    eb.textContent='Error loading jobs: '+err.message;
    eb.style.display='block';
  }
}

function getStatusClass(status){
  const s=(status||'').toLowerCase();
  if(s.includes('complete'))return{dot:'complete',badge:'status-complete',label:status};
  if(s.includes('confirmed')||s.includes('confirm'))return{dot:'confirmed',badge:'status-confirmed',label:status};
  return{dot:'booked',badge:'status-booked',label:status};
}

function isComplete(status){
  return(status||'').toLowerCase().includes('complete');
}

function filterJobs(filter,btn){
  currentFilter=filter;
  document.querySelectorAll('.ftab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  renderJobs();
}

function renderJobs(){
  const list=document.getElementById('jobs-list');
  let jobs=allJobs;
  if(currentFilter==='outstanding')jobs=allJobs.filter(j=>!isComplete(j.status));
  if(currentFilter==='complete')jobs=allJobs.filter(j=>isComplete(j.status));

  if(jobs.length===0){
    list.innerHTML=`<div class="empty-state">
      <div class="empty-icon">📋</div>
      <div class="empty-title">${currentFilter==='all'?'No jobs assigned to you':'No '+currentFilter+' jobs'}</div>
      <div class="empty-sub">${currentFilter==='all'?'Jobs assigned to you in Monday will appear here':'Check another filter'}</div>
    </div>`;
    return;
  }

  list.innerHTML=jobs.map(job=>{
    const sc=getStatusClass(job.status);
    const surveyUrl=SURVEY_URL+'?job='+job.id+'&name='+encodeURIComponent(job.name);
    return `<div class="job-item" onclick="openJob('${job.id}','${encodeURIComponent(job.name)}','${isComplete(job.status)}')">
      <div class="job-dot ${sc.dot}"></div>
      <div class="job-main">
        <div class="job-name">${job.name}</div>
        <div class="job-meta">Job #${job.id}${job.date?' · '+job.date:''}</div>
      </div>
      <div class="job-right">
        <span class="job-status ${sc.badge}">${sc.label}</span>
        <span class="job-date">${isComplete(job.status)?'Completed':'Outstanding'}</span>
      </div>
      <div class="job-arrow">›</div>
    </div>`;
  }).join('');
}

function updateStats(){
  const total=allJobs.length;
  const complete=allJobs.filter(j=>isComplete(j.status)).length;
  const outstanding=total-complete;
  document.getElementById('stat-total').textContent=total;
  document.getElementById('stat-complete').textContent=complete;
  document.getElementById('stat-outstanding').textContent=outstanding;
}

function openJob(itemId,encodedName,isComplete){
  const name=decodeURIComponent(encodedName);
  const url=SURVEY_URL+'?job='+itemId+'&name='+encodeURIComponent(name);
  window.location.href=url;
}

// Init
window.addEventListener('load',()=>{
  const saved=localStorage.getItem('bwd_portal_user');
  if(saved){
    currentUser=saved;
    document.getElementById('login-name').value=saved;
    showDashboard();
  }
});
</script>
</body>
</html>
